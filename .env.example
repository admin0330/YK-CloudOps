NODE_ENV=production
HOST=0.0.0.0
PORT=3001
APP_ORIGIN=http://8.162.24.188:3001

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Model: users choose Flash (deepseek-chat) or Pro (deepseek-v4-pro) in the UI
DEEPSEEK_MODEL=deepseek-v4-pro

SESSION_SECRET=change_this_to_a_long_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password

ALLOW_REGISTER=true
REGISTER_INVITE_CODE=change_this_invite_code

DATABASE_URL=file:./data/app.db

# JavaScript 学习页 MySQL source
JS_STUDY_DB_HOST=127.0.0.1
JS_STUDY_DB_PORT=3306
JS_STUDY_DB_USER=root
JS_STUDY_DB_PASSWORD=
JS_STUDY_DB_NAME=js_study

APP_TIMEZONE=Asia/Shanghai

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Image understanding (vision)
# Set ENABLE_IMAGE_UNDERSTANDING=true to let the AI read image content
ENABLE_IMAGE_UNDERSTANDING=true
# Model used for image understanding (defaults to DEEPSEEK_MODEL if not set)
VISION_MODEL=deepseek-v4-pro
# Max single image size for AI vision input in MB
MAX_IMAGE_PROMPT_MB=5
# Max images per message
MAX_IMAGES_PER_MESSAGE=4
